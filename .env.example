# ── Twitch Application ──
# Create at https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_client_id
TWITCH_CLIENT_SECRET=your_client_secret
TWITCH_REDIRECT_URI=https://your-domain.com/api/auth/twitch/callback
TWITCH_BOT_USERNAME=your_bot_username

# ── JWT ──
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=7d

# ── Encryption (AES-256) ──
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-to-a-64-hex-char-string

# ── Database ──
DATABASE_URL=postgresql://cristream:cristream@localhost:5432/cristream

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── App ──
NODE_ENV=production
PORT=3000
CORS_ORIGIN=https://your-domain.com

# ── Uploads ──
UPLOADS_DIR=uploads
PUBLIC_URL=https://your-domain.com

# ── EventSub (Twitch Webhooks) ──
EVENTSUB_SECRET=change-me-to-a-random-string
EVENTSUB_CALLBACK_URL=https://your-domain.com/api/eventsub/webhook

# ── Discord (optional) ──
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# ── AI Summaries (optional) ──
ANTHROPIC_API_KEY=

# ── Deploy (optional, for /deploy Discord command) ──
# DEPLOY_APP_DIR=/home/user/cristream
# DEPLOY_GIT_DIR=/home/user/cristream.git
